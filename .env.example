# =============================================================================
# SECURE OPERATOR — Environment Variables
# Stack: OpenClaw + NVIDIA OpenShell + NeMo-Claw + vLLM/Azure AI Foundry +
#        Milvus/Qdrant + OTel + NeMo Guardrails
# =============================================================================
# INSTRUCTIONS:
#   1. Copy this file: cp .env.example .env
#   2. Fill in every value marked with <CHANGE_ME>
#   3. Never commit .env to version control
# Install NeMo-Claw: curl -fsSL https://nvidia.com/nemoclaw.sh | bash
# =============================================================================

# --- Project ---
PROJECT_NAME=secure-operator
ENVIRONMENT=development           # development | staging | production
LOG_LEVEL=INFO

# =============================================================================
# INFERENCE — vLLM (local) or Azure AI Foundry (cloud)
# =============================================================================
INFERENCE_PROVIDER=vllm           # vllm | azure_ai_foundry | nvidia-nemotron

# vLLM (local Docker container)
VLLM_BASE_URL=http://localhost:8000
VLLM_API_KEY=token-secure-5678
VLLM_MODEL=nvidia/Nemotron-Mini-4B-Instruct

# Azure AI Foundry (alternative)
AZURE_AI_FOUNDRY_ENDPOINT=https://<CHANGE_ME>.services.ai.azure.com/models
AZURE_AI_FOUNDRY_API_KEY=<CHANGE_ME>
AZURE_AI_FOUNDRY_MODEL=gpt-4o
AZURE_AI_FOUNDRY_API_VERSION=2025-01-01-preview

# NVIDIA Nemotron (via NIM)
NEMOTRON_NIM_URL=http://localhost:8080
NEMOTRON_NIM_API_KEY=<CHANGE_ME>
NEMOTRON_MODEL=nvidia/nemotron-4-340b-instruct

# Inference parameters
INFERENCE_TEMPERATURE=0.0         # Low temp for deterministic code execution
INFERENCE_MAX_TOKENS=8192
INFERENCE_TIMEOUT_SECONDS=300     # Longer timeout for complex code tasks

# =============================================================================
# ORCHESTRATION — OpenClaw + NVIDIA OpenShell
# =============================================================================
OPENCLAW_WORKSPACE_DIR=/workspace/openclaw
OPENCLAW_LOG_LEVEL=INFO
OPENCLAW_MAX_ITERATIONS=25        # Max agent self-evolution steps
OPENCLAW_TOOL_TIMEOUT_SECONDS=60

# NVIDIA OpenShell runtime (sandboxed execution)
OPENSHELL_ENABLED=true
OPENSHELL_CONTAINER_IMAGE=nvcr.io/nvidia/openshell:latest
OPENSHELL_MAX_MEMORY_MB=2048
OPENSHELL_MAX_CPU_CORES=2
OPENSHELL_NETWORK_POLICY=isolated # isolated | restricted | full
OPENSHELL_EXECUTION_TIMEOUT=120   # Seconds per code execution job

# =============================================================================
# SECURITY — NVIDIA NeMo-Claw
# =============================================================================
NEMOCLAW_ENABLED=true
NEMOCLAW_PII_REDACTION=true
NEMOCLAW_JAILBREAK_DETECTION=true
NEMOCLAW_OUTPUT_FILTERING=true
NEMOCLAW_PRIVACY_MODE=strict      # strict | balanced | permissive
# Path to NeMo-Claw policy config (relative to project root)
NEMOCLAW_POLICY_PATH=./config/nemoclaw-policy.yaml

# NeMo Guardrails (additional semantic guardrails)
NEMO_GUARDRAILS_ENABLED=true
NEMO_GUARDRAILS_CONFIG_PATH=./config/nemo-guardrails/
NEMO_GUARDRAILS_EMBEDDING_MODEL=nv-embedqa-e5-v5

# =============================================================================
# VECTOR DATABASE — Milvus or Qdrant
# =============================================================================
VECTOR_DB_PROVIDER=milvus         # milvus | qdrant

# Milvus
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_USER=root
MILVUS_PASSWORD=<CHANGE_ME>
MILVUS_COLLECTION=secure_operator_docs

# Qdrant (alternative)
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=<CHANGE_ME>
QDRANT_COLLECTION_NAME=secure_operator_docs

# Embedding model
EMBEDDING_MODEL=nvidia/nv-embedqa-e5-v5
EMBEDDING_DIMENSION=1024

# =============================================================================
# TOOLS — Configurable agent tool registry
# =============================================================================
# Comma-separated list of enabled tools
ENABLED_TOOLS=python-interpreter,file-reader,web-search,sap-connector
# Python interpreter sandbox settings (via OpenShell)
PYTHON_SANDBOX_ENABLED=true
PYTHON_ALLOWED_PACKAGES=pandas,numpy,matplotlib,openpyxl,scipy
# SAP Connector (optional)
SAP_HOST=<CHANGE_ME>
SAP_CLIENT=100
SAP_USER=<CHANGE_ME>
SAP_PASSWORD=<CHANGE_ME>
SAP_SYSNR=00

# =============================================================================
# OBSERVABILITY — OpenTelemetry
# =============================================================================
OTEL_ENABLED=true
OTEL_SERVICE_NAME=secure-operator
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
NEMOCLAW_LOGS_TO_OTEL=true        # Forward NeMo-Claw logs via OTel

# =============================================================================
# API SERVER — FastAPI
# =============================================================================
API_HOST=0.0.0.0
API_PORT=8080
API_WORKERS=4
API_SECRET_KEY=<CHANGE_ME>
API_CORS_ORIGINS=http://localhost:3001

# =============================================================================
# COMPLIANCE
# =============================================================================
COMPLIANCE_STANDARD=ENS-Alto      # ENS-Alto | GDPR | SOC2 | ISO27001
AUDIT_LOGGING_ENABLED=true
SANDBOXED_EXECUTION_AUDIT=true    # Log all sandboxed code executions
